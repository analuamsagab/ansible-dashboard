# ============================================================
# Ansible Dashboard — Docker Deployment Env
# ============================================================
# Copy this file to .env before running docker compose.

# Frontend API URL (used at build time).
# With nginx proxying, use relative path /api
VITE_API_URL=/api

# JWT secret for auth tokens — change to a random string
JWT_SECRET=change-me-to-a-random-string

# Ansible job timeout in milliseconds (default 30 minutes)
JOB_TIMEOUT_MS=1800000
