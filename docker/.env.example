# ============================================================
# Ansible Dashboard — Docker Deployment Env
# ============================================================
# Copy this file to .env and fill in your Supabase project values.
#
# These are build-time args for the frontend container.
# Worker uses its own ../worker/.env file at runtime.
# ============================================================

# Your Supabase project URL (e.g. https://abc123.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe for frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
