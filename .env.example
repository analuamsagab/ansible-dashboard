# ============================================================
# Ansible Dashboard — Frontend Environment Variables
# ============================================================
# Copy this file to .env and fill in your Supabase project values.
# These values are PUBLIC — safe to ship to the browser.
#
# Where to find:
#   Supabase Dashboard → Project Settings → API
# ============================================================

# Your Supabase project URL (e.g. https://abc123.supabase.co)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon/public key (safe for frontend)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
