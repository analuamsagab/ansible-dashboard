# ============================================================
# Ansible Dashboard — Worker Environment Variables
# ============================================================
# Copy this file to .env and fill in your Supabase project values.
# These values are SECRET — never expose to the frontend.
#
# Where to find:
#   SUPABASE_URL / SERVICE_ROLE_KEY → Project Settings → API
# ============================================================

# Your Supabase project URL (same as frontend)
SUPABASE_URL=https://your-project-id.supabase.co

# Service role key (SECRET — bypasses RLS, keep safe!)
# NEVER use this key on the frontend.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Job execution timeout in milliseconds (default: 30 minutes)
JOB_TIMEOUT_MS=1800000
